{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "CourierHTTP default capabilities",
  "windows": ["main"],
  "permissions": [
    "core:path:default",
    "core:event:default",
    "core:window:default",
    "core:app:default",
    "core:resources:default",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-read-dir",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "dialog:allow-save"
  ]
}
